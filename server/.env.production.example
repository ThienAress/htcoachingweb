# Production contract only. Never commit real values.
# Put secrets in the hosting provider's secret manager.

NODE_ENV=production
PORT=5000

# Network and public origins
CLIENT_URL=https://app.example.com
PUBLIC_API_ORIGIN=https://api.example.com
ALLOWED_ORIGINS=https://app.example.com
PREVIEW_ORIGINS=
TRUST_PROXY_HOPS=1

# Database and independent signing secrets
MONGO_URI=
JWT_SECRET=
REFRESH_SECRET=
LOG_HASH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback
ADMIN_EMAIL=

# Bank transfer details
BANK_NAME=
BANK_CODE=
BANK_ACCOUNT=
BANK_HOLDER=

# Private media
F1_MEDIA_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
F1_CONSENT_VERSION=

# AI and email providers
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_IMAGE_PROVIDER=openai
OPENAI_API_KEY=
RESEND_API_KEY=

# Operations
OPS_METRICS_TOKEN=
BACKGROUND_JOBS_ENABLED=true
CSP_ENFORCE=false
F1_RETENTION_ENFORCE=false
F1_RETENTION_ACTOR_ID=

# HTTP lifecycle bounds
SERVER_HEADERS_TIMEOUT_MS=15000
SERVER_REQUEST_TIMEOUT_MS=120000
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_SHUTDOWN_TIMEOUT_MS=15000
